# Local Hub API - runs Lambda handlers via FastAPI. No AWS.
FROM python:3.12-slim

WORKDIR /app

# Copy deps first for layer caching
COPY requirements-local.txt requirements-local.txt

# Install deps before copying app (better cache)
RUN pip install --no-cache-dir -r requirements-local.txt

# Copy full app (api with lambda handlers, migrations for any in-container scripts)
COPY apps/api/ apps/api/

EXPOSE 8080

CMD ["uvicorn", "apps.api.local.app:app", "--host", "0.0.0.0", "--port", "8080"]
