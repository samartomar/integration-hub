# AWS API URLs for dev-ui / dev-ui-aws
# Copy to .env.aws and fill in your deployed API URLs.
# If customDomainRoot is set in packages/env-config/env-config.json,
# those URLs are used automatically; .env.aws overlays (e.g. for Okta).
#
# Admin portal: registry, audit, transactions
VITE_ADMIN_API_BASE_URL=https://admin-api.dev.your-domain.com
# Vendor portal: onboarding, vendor registry
VITE_VENDOR_API_BASE_URL=https://partners-api.dev.your-domain.com
# Runtime API: execute (single source – /v1/ai/execute, /v1/execute) for Admin & Vendor Execute pages
VITE_RUNTIME_API_BASE_URL=https://api.dev.your-domain.com
# Admin app URL (for "View transaction" links from Vendor portal)
VITE_ADMIN_APP_URL=https://cip.dev.your-domain.com
VITE_DEFAULT_VENDOR_CODE=LH001
#
# Okta (optional – if not set, apps use each app's .env / .env.local)
# Preferred: app-specific Okta overrides for split Admin/Vendor auth servers.
# Admin app:
# VITE_OKTA_ISSUER_ADMIN=https://integrator-8163795.okta.com/oauth2/default
# VITE_OKTA_CLIENT_ID_ADMIN=your_admin_client_id
# VITE_OKTA_AUDIENCE_ADMIN=api://default
# VITE_OKTA_SCOPES_ADMIN=openid profile email
# Optional callback override (otherwise defaults to <origin>/callback):
# VITE_OKTA_REDIRECT_URI_ADMIN=https://cip.dev.your-domain.com/callback
# VITE_OKTA_REDIRECT_PATH_ADMIN=/callback
# Vendor app:
# VITE_OKTA_ISSUER_VENDOR=https://integrator-8163795.okta.com/oauth2/your_vendor_auth_server
# VITE_OKTA_CLIENT_ID_VENDOR=your_vendor_client_id
# VITE_OKTA_AUDIENCE_VENDOR=api://hub-vendor
# VITE_OKTA_SCOPES_VENDOR=openid profile email
# Optional vendor-only IdP hint:
# VITE_OKTA_CONNECTION_VENDOR=your_okta_idp_id
# Optional callback override (otherwise defaults to <origin>/callback):
# VITE_OKTA_REDIRECT_URI_VENDOR=https://partners.dev.your-domain.com/callback
# VITE_OKTA_REDIRECT_PATH_VENDOR=/callback
#
# Backward-compatible shared Okta vars (applies to both apps if *_ADMIN/*_VENDOR not set):
# VITE_OKTA_ISSUER=https://integrator-8163795.okta.com/oauth2/default
# VITE_OKTA_CLIENT_ID=your_client_id
# VITE_OKTA_AUDIENCE=api://default
# VITE_OKTA_SCOPES=openid profile email
