# Local dev (make local-up): hub-api on 8080
VITE_VENDOR_API_BASE_URL=http://localhost:8080
# Runtime API: Execute always calls AWS (local mock cannot mimic Bedrock). Default: https://api.dev.aws.gosam.info
# VITE_RUNTIME_API_BASE_URL=https://api.dev.aws.gosam.info
# Optional: Admin app URL (for "View transaction" links)
# VITE_ADMIN_APP_URL=http://localhost:5173

# Okta (Vendor portal - SEPARATE from Admin): Vendor needs its own app in Okta.
# Allowed Callback URLs: http://localhost:5174 AND http://localhost:5174/callback (both required).
# VITE_OKTA_ISSUER=https://integrator-8163795.okta.com/oauth2/default
# VITE_OKTA_CLIENT_ID=your_vendor_client_id     # NOT the Admin client ID
# VITE_OKTA_AUDIENCE=api://default              # REQUIRED for AWS endpoints; omit for local (AUTH_BYPASS)
# VITE_OKTA_SCOPES=openid profile email
# VITE_OKTA_CONNECTION=your_okta_idp_id         # Optional brokered IdP id
