# Local dev (make local-up): hub-api serves Admin + Vendor APIs on 8080
VITE_ADMIN_API_BASE_URL=http://localhost:8080
# Runtime API: Execute always calls AWS (local mock cannot mimic Bedrock). Override with VITE_RUNTIME_API_BASE_URL if needed.
# VITE_RUNTIME_API_BASE_URL=https://api.dev.aws.gosam.info

# Okta (Admin portal - SEPARATE from Vendor): Admin needs its own app in Okta.
# Allowed Callback URLs: http://localhost:5173 AND http://localhost:5173/callback (both required).
# Allowed Logout URLs: http://localhost:5173.
# VITE_OKTA_ISSUER=https://integrator-8163795.okta.com/oauth2/default
# VITE_OKTA_CLIENT_ID=your_admin_client_id   # NOT the Vendor client ID
# VITE_OKTA_AUDIENCE=api://default           # REQUIRED for AWS endpoints; omit for local (AUTH_BYPASS)
# VITE_OKTA_SCOPES=openid profile email
